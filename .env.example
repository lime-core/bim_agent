# Required: EIR server URL
SERVER_URL=http://localhost:3000

# Required: API key from agent registration in EIR UI
API_KEY=your-api-key-here

# Optional: Heartbeat interval in ms (default: 30000)
# HEARTBEAT_INTERVAL_MS=30000

# Optional: Build polling interval in ms (default: 10000)
# POLL_INTERVAL_MS=10000

# Optional: Working directory for build artifacts (default: ./work)
# WORK_DIR=./work

# Optional: Autodesk base installation path (default: C:\Program Files\Autodesk)
# Tools are auto-resolved by Revit version from data source settings:
#   Navisworks: {base}\Navisworks Manage {version}\FileToolsTaskRunner.exe
#   RevitServerTool: {base}\Revit {version}\RevitServerToolCommand\RevitServerTool.exe
# AUTODESK_BASE_PATH=C:\Program Files\Autodesk

# Optional: Navisworks language (default: ru-RU)
# NAVISWORKS_LANG=ru-RU

# Optional: Child process timeout in ms (default: 1800000 = 30 min)
# PROCESS_TIMEOUT_MS=1800000

# Optional: Encoding for Autodesk tools stdout/stderr (default: utf-8)
# On Russian Windows where tools output in Windows-1251 or CP866, set accordingly.
# Use 'cp1251' for most Autodesk GUI-derived tools (RevitServerTool, FileToolsTaskRunner).
# Use 'cp866' for classic OEM console tools.
# PROCESS_ENCODING=cp1251
