# Обязательно: URL bepkeeper сервера
SERVER_URL=https://bepkeeper.ru

# Обязательно: API-ключ из раздела "Настройки → Агенты" в bepkeeper
API_KEY=your-api-key-here

# Опционально: интервал heartbeat в мс (по умолчанию: 30000)
# HEARTBEAT_INTERVAL_MS=30000

# Опционально: интервал опроса заданий в мс (по умолчанию: 10000)
# POLL_INTERVAL_MS=10000

# Опционально: рабочий каталог для артефактов сборки (по умолчанию: ./work)
# WORK_DIR=./work

# Опционально: базовый путь установки Autodesk (по умолчанию: C:\Program Files\Autodesk)
# Инструменты определяются автоматически по версии Revit из настроек источника данных:
#   Navisworks: {base}\Navisworks Manage {version}\FileToolsTaskRunner.exe
#   RevitServerTool: {base}\Revit {version}\RevitServerToolCommand\RevitServerTool.exe
# AUTODESK_BASE_PATH=C:\Program Files\Autodesk

# Опционально: язык Navisworks (по умолчанию: ru-RU)
# NAVISWORKS_LANG=ru-RU

# Опционально: таймаут дочернего процесса в мс (по умолчанию: 1800000 = 30 мин)
# PROCESS_TIMEOUT_MS=1800000

# Опционально: кодировка stdout/stderr инструментов Autodesk (по умолчанию: utf-8)
# На русской Windows, где инструменты выводят в Windows-1251 или CP866, задайте соответственно.
# Используйте 'cp1251' для GUI-инструментов Autodesk (RevitServerTool, FileToolsTaskRunner).
# Используйте 'cp866' для классических OEM-консольных инструментов.
# PROCESS_ENCODING=cp1251

# Опционально: учётные данные локального Revit Server.
# Используются только когда DataSource в bepkeeper помечен "Использовать учётные данные агента"
# (use_agent_credentials=true). В этом случае сервер не передаёт пароль в ответе на опрос,
# а агент подставляет эти значения для REST Basic Auth.
# Оставьте закомментированным, если используете учётные данные уровня DataSource, хранимые в bepkeeper.
# REVIT_SERVER_USERNAME=domain\user
# REVIT_SERVER_PASSWORD=
